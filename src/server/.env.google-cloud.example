# Google Cloud multiplayer host (34.135.182.35).
# Copy to src/server/.env on the VM and fill every secret there.
NODE_ENV=production
MULTIPLAYER_MODE=true
MULTIPLAYER_BASE_IP=34.135.182.35
PUBLIC_BASE_URL=http://34.135.182.35
STATIC_PORT=80
GAME_PORT=8080
POLICY_PORT=843
ENABLE_POLICY_SERVER=true

# Discord OAuth. Keep all secrets on the VM only.
DISCORD_CLIENT_ID=1447954255452311695
DISCORD_CLIENT_SECRET=replace-with-discord-client-secret
DISCORD_REDIRECT_URI=https://discord-github-assistant-bot.vercel.app/api/discord-oauth-callback
DISCORD_ACCOUNT_LINK_STATE_SECRET=
DISCORD_LINKED_ROLES_CONNECT_URL=https://discord-github-assistant-bot.vercel.app/api/discord-linked-roles/connect

# Complete game-account, save, and wallet persistence.
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=minidb
ENABLE_MONGO_GAME_DATA=true
MONGODB_ACCOUNTS_COLLECTION=accounts
MONGODB_SAVES_COLLECTION=saves
MONGODB_COUNTERS_COLLECTION=counters
ENABLE_MONGO_WALLET=true
MONGODB_WALLET_COLLECTION=data
MONGO_WALLET_FLUSH_INTERVAL_MS=5000

# Sponsor/contributor eligibility uses the same Mongo deployment by default.
SPONSOR_MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
SPONSOR_MONGODB_DB_NAME=github-sponsors
SPONSOR_MONGODB_COLLECTION=data
SPONSOR_DISCORD_ID_FIELDS=userId,_id
SPONSOR_STATUS_FIELD=isSponsor,isContributor
SPONSOR_ACCOUNT_CREATION_REQUIRED=true

# Optional server integrations.
DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_SOCIAL_GUILD_ID=1295512336353722438
TRUST_PROXY_HEADERS=false
