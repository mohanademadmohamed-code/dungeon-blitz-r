{
  "name": "server",
  "version": "1.9.5",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch main.ts --watch auth --watch core --watch database --watch handlers --watch integrations --watch network --watch utils --watch tools/runDevServer.js --ext ts,js --ignore dist --ignore test --ignore data/saves --exec \"node tools/runDevServer.js\"",
    "multiplayer": "node --env-file-if-exists=.env tools/startMultiplayerServer.js",
    "dev:discord-bridge": "ts-node tools/discordLocalBridge.ts discord-bridge.dev.config.json",
    "install:discord-social-sdk": "node tools/installDiscordSocialSdk.js",
    "start:multiplayer:game": "node tools/startMultiplayerServer.js",
    "build": "tsc",
    "start:multiplayer": "node tools/startMultiplayerServer.js",
    "start:discord-bridge": "node tools/startDiscordBridge.js",
    "start:discord-bridge:multiplayer": "node tools/startDiscordBridge.js",
    "reset-password": "ts-node scripts/set_account_password.ts",
    "migrate:game-data-to-mongo": "node --env-file-if-exists=.env -r ts-node/register scripts/migrate_game_data_to_mongo.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "cross-env": "^10.0.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "discord-rpc": "^4.0.1",
    "express": "^5.2.1",
    "mongodb": "^7.4.0"
  }
}
