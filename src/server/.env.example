# Copy this file to src/server/.env for local Discord Social SDK settings.
# Single-player/local development works without this file.

# Optional Discord Social SDK bridge.
DISCORD_SOCIAL_BRIDGE_ENABLED=true
DISCORD_SOCIAL_NATIVE_BRIDGE_ENABLED=true
DISCORD_SOCIAL_CHAT_RELAY_MODE=native
DISCORD_SOCIAL_APP_ID=1447954255452311695
DISCORD_SOCIAL_BRIDGE_CHANNEL_ID=1296158709529055253
DISCORD_SOCIAL_DEVICE_FLOW=false

# Required Discord OAuth account bootstrap settings.
# Use your own Discord application credentials. Do not commit real secrets.
DISCORD_CLIENT_ID=1447954255452311695
DISCORD_CLIENT_SECRET=
# Must exactly match a redirect URI registered in the Discord developer portal.
# The Vercel relay bounces the browser back to PUBLIC_BASE_URL on this server.
DISCORD_REDIRECT_URI=https://discord-github-assistant-bot.vercel.app/api/discord-oauth-callback
PUBLIC_BASE_URL=http://localhost:8000
DISCORD_ACCOUNT_LINK_STATE_SECRET=
DISCORD_LINKED_ROLES_CONNECT_URL=https://discord-github-assistant-bot.vercel.app/api/discord-linked-roles/connect

# All user account/save data lives in MongoDB when enabled.
# SPONSOR_* values default to MONGODB_URI / MONGODB_DB_NAME when omitted.
MONGODB_URI=
MONGODB_DB_NAME=minidb
ENABLE_MONGO_GAME_DATA=true
MONGODB_ACCOUNTS_COLLECTION=accounts
MONGODB_SAVES_COLLECTION=saves
MONGODB_COUNTERS_COLLECTION=counters
SPONSOR_MONGODB_URI=
SPONSOR_MONGODB_DB_NAME=
SPONSOR_MONGODB_COLLECTION=data
SPONSOR_DISCORD_ID_FIELDS=userId,_id
SPONSOR_STATUS_FIELD=isSponsor,isContributor
SPONSOR_ACCOUNT_CREATION_REQUIRED=true

# Optional bot/server API settings.
# Required only for bot REST channel relay or channel-link permission grants.
# Do not commit a real bot token.
DISCORD_BOT_TOKEN=
DISCORD_SOCIAL_GUILD_ID=

# Optional advanced settings.
DUNGEONBLITZ_KEY_HEX=
DISCORD_SOCIAL_LOBBY_SECRET=
DISCORD_SOCIAL_ENABLE_CHANNEL_LINKING=false
DISCORD_SOCIAL_BRIDGE_LOG_PAYLOADS=false
TRUST_PROXY_HEADERS=false
