{
    "name": "dungeon-blitz-r",
    "version": "1.10.10",
    "description": "Dungeon Blitz: R",
    "main": "index.js",
    "scripts": {
        "dev": "cd src/server && npm run dev",
        "multiplayer": "cd src/server && npm run multiplayer",
        "build": "cd src/server && npm run build",
        "start:multiplayer": "cd src/server && npm run start:multiplayer:game",
        "start:discord-bridge": "cd src/server && npm run start:discord-bridge",
        "dev:discord": "npm run dev:with-discord",
        "launch:multiplayer-with-discord": "node src/server/tools/launchMultiplayerClient.js",
        "install:discord-social-sdk": "node src/server/tools/installDiscordSocialSdk.js",
        "install:discord-bridge-autostart": "node src/server/tools/installDiscordBridgeAutostart.js",
        "remove:discord-bridge-autostart": "node src/server/tools/removeDiscordBridgeAutostart.js",
        "dev:discord-bridge": "cd src/server && npm run dev:discord-bridge",
        "dev:with-discord": "concurrently -n GAME,RPC -c blue,magenta \"npm run dev\" \"npm run dev:discord-bridge\"",
        "reset-password": "cd src/server && npm run reset-password --",
        "migrate:game-data-to-mongo": "cd src/server && npm run migrate:game-data-to-mongo --",
        "pm2:setup:google-cloud": "bash scripts/setup-google-cloud-pm2.sh",
        "pm2:start": "pm2 startOrReload ecosystem.config.cjs --env production",
        "pm2:logs": "pm2 logs dungeon-blitz-multiplayer",
        "export:goblin-kidnappers-spawns": "node src/server/tools/exportGoblinKidnappersEnemies.js",
        "test:goblin-kidnappers-authority": "cd src/server && ts-node --transpile-only test/goblin_kidnappers_server_authority_regression.ts"
    },
    "devDependencies": {
        "concurrently": "^10.0.3"
    },
    "author": "The Minesa Studios",
    "license": "MIT"
}
